<div id="nav-debug-container" style="border: 1px solid red;">
    <a href="/">← Главная</a>
    <span id="dynamic-nav-back"></span>
    {% if page.categories.size > 0 %}
        {% assign project_slug = "" %}
        {% for cat in page.categories %}
            {% if cat != "feed" and cat != "journal" and cat != "media" and cat != "diary" %}
                {% assign project_slug = cat %}
            {% endif %}
        {% endfor %}
        {% assign project_page = site.pages | where_exp: "item", "item.url contains project_slug" | first %}

        | <a href="{{ project_page.url | relative_url }}">Назад</a>
    {% else %}
        {% assign parts = page.url | split: '/' %}
        {% if parts.size > 2 %}
            {% assign parent_url = parts[1] | prepend: '/' | append: '/' %}
            {% assign parent_page = site.pages | where: "url", parent_url | first %}

            | <a href="{{ parent_url | relative_url }}">{{ parent_page.navtitle | default: parent_page.title | default: parts[1] }}</a>
        {% endif %}
    {% endif %}

    | <a href="/tags.html"># Поиск</a>
</div>

<script>
  (function() {
    console.log("Debug: Start JS");
    var params = new URLSearchParams(window.location.search);
    var prj = params.get('project'), navDir = params.get('nav');
    
    // Дебаг в консоль браузера (F12 -> Console)
    console.log("Project:", prj, "Nav:", navDir);

    if (prj && navDir) {
      var backBox = document.getElementById('dynamic-nav-back');
      if (backBox) {
        backBox.innerHTML = ' | <a href="/' + navDir + '/' + prj + '/">Назад</a>';
      }
    }
  })();
</script>
