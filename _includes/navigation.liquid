<div class="navigation-header" style="margin-bottom: 15px; font-size: 0.9rem; border-bottom: 1px solid #f0f0f0; padding-bottom: 8px;">
    <a href="/" class="back-link" style="margin-bottom: 0; color: #3498db; font-weight: normal;">← Главная</a>

    {% assign parent_page = nil %}
    {% assign parent_url = "" %}

    {% if page.git-section %}
        {% comment %} Логика для коллекций: ищем по git-section {% endcomment %}
        {% assign parent_url = page.git-section | prepend: '/' | append: '/' %}
        {% assign parent_page = site.pages | where: "permalink", parent_url | first %}
    {% else %}
        {% comment %} Логика для обычных страниц: ищем по URL {% endcomment %}
        {% assign parts = page.url | split: '/' %}
        {% if parts.size > 2 %}
            {% assign parent_url = parts[1] | prepend: '/' | append: '/' %}
            {% assign parent_page = site.pages | where: "url", parent_url | first %}
        {% endif %}
    {% endif %}

    {% if parent_page or parent_url != "" %}
        <span style="color: #ccc; margin: 0 5px;">|</span>
        <a href="{{ parent_url | relative_url }}" class="back-link" style="margin-bottom: 0;">
            {% if parent_page %}
                {{ parent_page.navname | default: parent_page.title }}
            {% else %}
                {{ parent_url | remove: '/' | capitalize }}
            {% endif %}
        </a>
    {% endif %}

    <span style="color: #ccc; margin: 0 5px;">|</span>
    <a href="/tags.html" class="back-link" style="margin-bottom: 0; color: #3498db; font-weight: normal;"># Поиск</a>
</div>
