<div class="navigation-header" style="margin-bottom: 15px; font-size: 0.9rem; border-bottom: 1px solid #f0f0f0; padding-bottom: 8px;">
    <a href="/" class="back-link" style="margin-bottom: 0; color: #3498db; font-weight: normal;">← Главная</a>

    {% comment %} Место для кнопки "Назад", которую вставит скрипт на странице /photos/ {% endcomment %}
    <span id="dynamic-back"></span>

    {% if page.categories.size > 0 %}
        {% comment %} Логика для ПОСТОВ (дневников) {% endcomment %}
        {% assign project_slug = page.categories | first %}
        {% assign project_url = project_slug | prepend: '/fair/' | append: '/' %}
        <span style="color: #ccc; margin: 0 5px;">|</span>
        <a href="{{ project_url | relative_url }}" class="back-link" style="margin-bottom: 0;">Назад</a>
    {% else %}
        {% comment %} Логика для обычных СТРАНИЦ {% endcomment %}
        {% assign parts = page.url | split: '/' %}
        {% if parts.size > 2 %}
            {% comment %} Берем вторую часть пути (индекс 1), так как первая пустая из-за начального слэша {% endcomment %}
            {% assign section_slug = parts[1] %}
            {% assign parent_url = section_slug | prepend: '/' | append: '/' %}
            {% assign parent_page = site.pages | where: "url", parent_url | first %}

            <span style="color: #ccc; margin: 0 5px;">|</span>
            <a href="{{ parent_url | relative_url }}" class="back-link" style="margin-bottom: 0;">
                {{ parent_page.git-title | default: parent_page.title | default: section_slug }}
            </a>
        {% endif %}
    {% endif %}

    <span style="color: #ccc; margin: 0 5px;">|</span>
    <a href="/tags.html" class="back-link" style="margin-bottom: 0; color: #3498db; font-weight: normal;"># Поиск</a>
</div>
