<div class="navigation-header" style="margin-bottom: 15px; font-size: 0.9rem; border-bottom: 1px solid #f0f0f0; padding-bottom: 8px;">
    <a href="/" class="back-link" style="margin-bottom: 0; color: #3498db; font-weight: normal;">← Главная</a>

    {% comment %} Место для вставки "Назад" на страницах архивов {% endcomment %}
    <span id="dynamic-nav-back"></span>

    {% if page.categories.size > 0 %}
        {% assign project_slug = "" %}
        {% for cat in page.categories %}
            {% if cat != "feed" and cat != "journal" and cat != "media" and cat != "diary" %}
                {% assign project_slug = cat %}
            {% endif %}
        {% endfor %}
        {% assign project_page = site.pages | where_exp: "item", "item.url contains project_slug" | first %}
        <span style="color: #ccc; margin: 0 5px;">|</span>
        <a href="{{ project_page.url | relative_url }}" class="back-link" style="margin-bottom: 0; max-width: 140px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: inline-block; vertical-align: bottom;">{{ project_page.navtitle | default: project_page.title | default: "Назад" }}</a>
    {% else %}
        {% assign parts = page.url | split: '/' %}
        {% if parts.size > 2 %}
            {% assign parent_url = parts[1] | prepend: '/' | append: '/' %}
            {% assign parent_page = site.pages | where: "url", parent_url | first %}
            <span style="color: #ccc; margin: 0 5px;">|</span>
            <a href="{{ parent_url | relative_url }}" class="back-link" style="margin-bottom: 0;">
                {{ parent_page.navtitle | default: parent_page.title | default: parts[1] }}
            </a>
        {% endif %}
    {% endif %}

    <span style="color: #ccc; margin: 0 5px;">|</span>
    <a href="/tags.html" class="back-link" style="margin-bottom: 0; color: #3498db; font-weight: normal;"># Поиск</a>
</div>

<script>
  (function() {
    var params = new URLSearchParams(window.location.search);
    var prj = params.get('project'), navDir = params.get('nav');
    if (prj && navDir) {
      var bb = document.getElementById('dynamic-nav-back');
      if (bb) {
        // Добавляем пробел перед span и внутри span вокруг палочки, как это делает Jekyll
        bb.innerHTML = ' <span style="color: #ccc; margin: 0 5px;">|</span> ' +
                       '<a href="/' + navDir + '/' + prj + '/" class="back-link" style="margin-bottom: 0; max-width: 140px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: inline-block; vertical-align: bottom;">{{ project_page.navtitle | default: project_page.title | default: "Назад" }}</a>';
      }
    }
  })();
</script>