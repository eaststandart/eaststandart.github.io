<div class="navigation-header" style="margin-bottom: 15px; font-size: 0.9rem; border-bottom: 1px solid #f0f0f0; padding-bottom: 8px;">
    <a href="/" class="back-link" style="margin-bottom: 0; color: #3498db; font-weight: normal;">← Главная</a>

    {% if page.git-section %}
        {% comment %} Ищем страницу, у которой permalink совпадает с разделом проекта {% endcomment %}
        {% assign section_url = page.git-section | prepend: '/' | append: '/' %}
        {% assign parent_page = site.pages | where: "permalink", section_url | first %}

        <span style="color: #ccc; margin: 0 5px;">|</span>
        <a href="{{ section_url | relative_url }}" class="back-link" style="margin-bottom: 0;">
            {{ parent_page.navname | default: parent_page.title | default: page.git-section }}
        </a>
    {% endif %}

    <span style="color: #ccc; margin: 0 5px;">|</span>
    <a href="/tags.html" class="back-link" style="margin-bottom: 0; color: #3498db; font-weight: normal;"># Поиск</a>
</div>
