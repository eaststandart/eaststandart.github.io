{% comment %} 
=============================================================================
ДЕБАГ-ВЕРСИЯ: ЛОКАЛЬНЫЙ ЖУРНАЛ ПРОЕКТА (_includes/project-loop.liquid)
=============================================================================
{% endcomment %}

<div style="background: #fff3cd; border: 1px solid #ffeeba; color: #856404; padding: 10px; margin: 10px 0; font-family: monospace; font-size: 0.85rem; border-radius: 6px;">
  <strong>⚙️ ДЕБАГ ЛЕНТЫ ПРОЕКТА (Запрос: {{ include.collection }} | Папка: {{ include.folder }}):</strong>
  <ul style="margin: 5px 0 0 0; padding-left: 20px;">
    
    {% if include.collection == "journal" %}
      {% assign current_collection = site.journal %}
      <li>Выбрана коллекция: site.journal (Всего файлов в базе Jekyll: {{ site.journal.size }})</li>
    {% elsif include.collection == "media" %}
      {% assign current_collection = site.media %}
      <li>Выбрана коллекция: site.media (Всего файлов в базе Jekyll: {{ site.media.size }})</li>
    {% else %}
      {% assign current_collection = site.journal | concat: site.media %}
      <li>Выбрана сквозная коллекция (Всего файлов: {{ current_collection.size }})</li>
    {% endif %}

    {% assign found_count = 0 %}
    {% for item in current_collection %}
      {% comment %} Проверяем, содержит ли путь или ссылка имя папки робота {% endcomment %}
      {% if item.path contains include.folder or item.url contains include.folder %}
        {% assign found_count = found_count | plus: 1 %}
        
        {% comment. %} Рендерим элемент списка прямо внутри дебага, чтобы проверить видимость {% endcomment %}
        <li style="color: #155724; margin-top: 5px;">
          🟢 Найдено совпадение! Файл: <code style="background:#d4edda;">{{ item.path }}</code> <br>
          Ссылка: <a href="{{ item.url | relative_url }}" style="color: #0056b3; font-weight: bold;">{{ item.title | default: "Без заголовка" }}</a>
        </li>
      {% endif %}
    {% endfor %}
    
    <li style="margin-top: 5px; font-weight: bold;">ИТОГО совпадений для блока найдено: {{ found_count }}</li>
  </ul>
</div>
