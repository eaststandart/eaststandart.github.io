{% comment %} 
=============================================================================
МОДУЛЬ: ЛОКАЛЬНЫЙ ЖУРНАЛ И ГАЛЕРЕЯ ПРОЕКТА (_includes/project-loop.liquid)
Назначение: Автоматически собирает посты конкретного робота из его категории.
Оригинал: Построен на базе твоего эталонного скрипта project-list.liquid.
Параметры: include.type ("journal" или "media" для фильтрации категории постов).
=============================================================================
{% endcomment %}

{% comment %} 1. Автоматическое вычисление адресов и названий разделов из URL страницы {% endcomment %}
{% assign url_parts = page.url | split: "/" %}
{% assign section_slug = url_parts[1] %}
{% assign project_slug = url_parts[2] %}
{% assign section_url = section_slug | prepend: "/" | append: "/" %}
{% assign section_page = site.pages | where: "url", section_url | first %}

{% assign project_slug_last = page.url | split: "/" | last %}

{% comment %} 
   2. Счётчик-предохранитель: проверяем, есть ли вообще посты для этого блока, 
   чтобы не выводить пустые контейнеры, если журнала или галереи не существует.
{% endcomment %}
{% assign has_posts = false %}
{% for post in site.categories[project_slug_last] %}
  {% if post.categories contains include.type %}
    {% assign has_posts = true %}
    {% break %}
  {% endif %}
{% endfor %}

{% if has_posts %}
<ul class="project-list" style="list-style: none; padding: 0; margin: 0 0 20px 0;">
  
  {% comment %} Умная ссылка «Смотреть все →» — теперь строго в ЕДИНОМ синем цвете #0366d6 {% endcomment %}
  <li style="margin-bottom: 12px;">
    <strong>
      <a href="/{{ include.type }}/?project={{ project_slug }}&nav={{ section_slug }}&title={{ section_page.navtitle | default: section_slug }}" style="color: #0366d6; text-decoration: none;">
        Смотреть все →
      </a>
    </strong>
  </li>

  {% comment %} 3. Вывод самих компактных строк постов по твоей хронологии {% endcomment %}
  {% for post in site.categories[project_slug_last] %}
    {% if post.categories contains include.type %}
      {% assign is_post = true %}
      {% if include.type == "media" %}{% assign is_post = false %}{% endif %}

      <li class="news-item-compact" data-date="{{ post.date | date: '%Y-%m-%d' }}" data-is-post="{{ is_post }}" data-emoji="">
        <small>{{ post.date | date: "%d.%m.%Y" }}&nbsp;»&nbsp;</small> 
        <a href="{{ post.url | relative_url }}" class="item-link">
          {{ post.title }}
        </a>
      </li>
    {% endif %}
  {% endfor %}
</ul>
{% endif %}
