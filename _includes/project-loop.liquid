{% comment %} 
=============================================================================
МОДУЛЬ: ЛОКАЛЬНЫЙ ЖУРНАЛ И ГАЛЕРЕЯ ПРОЕКТА С ДИНАМИЧЕСКОЙ НАСТРОЙКОЙ СТРОК (_includes/project-loop.liquid)
Назначение: Собирает посты робота. Делит на страницы по лимиту per_page.
Безопасность: Полностью автономный скрипт пагинации, не влияет на главную и архив.
=============================================================================
{% endcomment %}

{% assign url_parts = page.url | split: "/" %}
{% assign section_slug = url_parts[1] %}
{% assign project_slug = url_parts[2] %}
{% assign section_url = section_slug | prepend: "/" | append: "/" %}
{% assign section_page = site.pages | where: "url", section_url | first %}

{% assign project_slug_last = page.url | split: "/" | last %}

{% comment %} Счётчик-предохранитель наличия постов {% endcomment %}
{% assign has_posts = false %}
{% for post in site.categories[project_slug_last] %}
  {% if post.categories contains include.type %}
    {% assign has_posts = true %}
    {% break %}
  {% endif %}
{% endfor %}

{% if has_posts %}
{% comment %} Генерируем уникальные ID для каждого блока на странице {% endcomment %}
{% assign loop_id = include.type | append: "-" | append: project_slug_last %}
{% assign ctrl_id = "ctrl-" | append: loop_id %}

<ul id="{{ loop_id }}" class="project-list" style="list-style: none; padding: 0; margin: 0 0 15px 0;">
  
  {% comment %} Умная ссылка «Смотреть все →» в цвете навигации #3498db {% endcomment %}
  <li class="nav-all-link" style="margin-bottom: 12px;">
    <strong>
      <a href="{{ '/journal/' | relative_url }}" style="color: #3498db; text-decoration: none;">
        Смотреть все →
      </a>
    </strong>
  </li>

  {% comment %} Вывод компактных строк постов {% endcomment %}
  {% for post in site.categories[project_slug_last] %}
    {% if post.categories contains include.type %}
      {% assign is_post = true %}
      {% if include.type == "media" %}{% assign is_post = false %}{% endif %}

      <li class="news-item-compact local-post-item" data-date="{{ post.date | date: '%Y-%m-%d' }}" data-is-post="{{ is_post }}" data-emoji="">
        <small>{{ post.date | date: "%d.%m.%Y" }}&nbsp;»&nbsp;</small> 
        <a href="{{ post.url | relative_url }}" class="item-link">
          {{ post.title }}
        </a>
      </li>
    {% endif %}
  {% endfor %}
</ul>

{% comment %} Посадочное место для мини-кнопок локальной пагинации {% endcomment %}
<div id="{{ ctrl_id }}" style="display: flex; gap: 5px; margin-bottom: 25px;"></div>

{% comment %} 
  АВТОНОМНЫЙ СКРИПТ ПОСТРАНИЧНОЙ ЛОКАЛЬНОЙ ПАГИНАЦИИС ДИНАМИЧЕСКИМ ЛИМИТОМ
{% endcomment %}
<script>
  (function() {
    var containerId = "{{ loop_id }}";
    var ctrlId = "{{ ctrl_id }}";
    
    var ul = document.getElementById(containerId);
    var ctrlDiv = document.getElementById(ctrlId);
    if (!ul || !ctrlDiv) return;

    var allItems = Array.from(ul.querySelectorAll('.local-post-item'));
    
    // ДИНАМИЧЕСКИЙ НАСТРОЕЧНЫЙ ЛИМИТ: берём параметр per_page, если его нет — ставим 5 по умолчанию
    var itemsPerPage = parseInt("{{ include.per_page }}") || 5; 
    
    var totalPages = Math.ceil(allItems.length / itemsPerPage);
    var currentPage = 1;

    if (totalPages <= 1) {
      ctrlDiv.style.display = 'none';
      return;
    }

    function showPage(page) {
      currentPage = page;
      var start = (page - 1) * itemsPerPage;
      var end = start + itemsPerPage;

      allItems.forEach(function(el, index) {
        if (index >= start && index < end) {
          el.style.setProperty('display', 'flex', 'important');
        } else {
          el.style.setProperty('display', 'none', 'important');
        }
      });

      renderButtons();
    }

    function renderButtons() {
      ctrlDiv.innerHTML = '';
      
      for (var i = 1; i <= totalPages; i++) {
        var btn = document.createElement('button');
        btn.innerText = i;
        
        btn.style.padding = '3px 8px';
        btn.style.border = '1px solid #e1e4e8';
        btn.style.borderRadius = '4px';
        btn.style.cursor = 'pointer';
        btn.style.fontSize = '0.8rem';
        btn.style.fontWeight = 'bold';
        
        if (i === currentPage) {
          btn.style.backgroundColor = '#3498db';
          btn.style.color = '#fff';
          btn.style.borderColor = '#3498db';
        } else {
          btn.style.backgroundColor = '#fff';
          btn.style.color = '#24292e';
        }

        (function(pageIndex) {
          btn.addEventListener('click', function() {
            showPage(pageIndex);
          });
        })(i);

        ctrlDiv.appendChild(btn);
      }
    }

    showPage(1);
  })();
</script>
{% endif %}
