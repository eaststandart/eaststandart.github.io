<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page.title }}</title>
    <link rel="icon" type="image/svg+xml" href="/assets/icons/favicon.svg">

    <!-- ... БАЗОВЫЕ СТИЛИ ... -->
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="/assets/css/video.css">

    <!-- УНИВЕРСАЛЬНЫЙ КОД ДЛЯ ВСЕХ ШАБЛОНОВ -->
    {% if layout.layout_css %}
      <link rel="stylesheet" href="{{ layout.layout_css | relative_url }}">
    {% endif %}

    <!-- СТИЛИ КОНКРЕТНОЙ СТРАНИЦЫ -->
    {% if page.custom_css %}
      {% for style in page.custom_css %}
        <link rel="stylesheet" href="{{ style | relative_url }}">
      {% endfor %}
    {% endif %}
</head>
<body>

<div class="content-wrapper">
        
<!-- Блок навигации -->
<div class="navigation-header" style="border: 2px solid blue; padding: 10px; font-family: monospace;">
    {% assign parts = page.url | split: '/' %}
    
    DEBUG ARRAY:
    {% for p in parts %}
      {{ forloop.index }}: [{{ p }}] |
    {% endfor %}
    <br>
    SIZE: {{ parts.size }}

    <hr>

    <a href="/">← Главная</a>

    {% comment %} 
       Пробуем найти первый элемент, который НЕ пустой.
       Обычно в /fair/robot/ это: 1:[], 2:[fair], 3:[robot]
    {% endcomment %}
    {% assign parent_dir = "" %}
    {% if parts[1] != "" %}{% assign parent_dir = parts[1] %}
    {% elsif parts[2] != "" %}{% assign parent_dir = parts[2] %}{% endif %}

    {% if parent_dir != "" and page.url != "/fair/" and page.url != "/fair" %}
        <span>|</span>
        <a href="/{{ parent_dir }}/">
            {% if parent_dir == "fair" %}Поделки{% else %}{{ parent_dir }}{% endif %}
        </a>
    {% endif %}
</div>

    <h1 style="margin-top: 0;">{{ page.title }}</h1> 

    <div class="main-content">
        {{ page.description }}
        {{ content }}
    </div>
    
    <!-- Универсальный блок библиографии -->
    {% if page.bibliography %}
    <div class="bibliography-footer">
        <strong>Библиографическое описание:</strong>
        
        {% if page.bibliography.first %}
            <ol style="margin: 0; padding-left: 25px;">
                {% for item in page.bibliography %}
                <li style="margin-bottom: 8px;">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</li>
                {% endfor %}
            </ol>
        {% else %}
            {{ page.bibliography | markdownify }}
        {% endif %}
    </div>
    {% endif %}

    {% if page.sources %}
    <div class="sources-inline">
        <strong>Источники:</strong> 
        <div class="sources-content">
            {{ page.sources | markdownify }}
        </div>
    </div>
    {% endif %}

    {% if page.tags %}
    <div class="tag-container">
        {% for tag in page.tags %}
        {% assign tag_clean = tag | replace: '#', '' | strip %}
        <a href="{{ '/tags.html' | relative_url }}#{{ tag_clean | slugify }}" class="tag-item">{{ tag_clean }}</a>
        {% endfor %}
    </div>
    {% endif %}

</div>

<footer class="license-footer">
    <p style="margin-top: 0px; margin-bottom: 5px;">
        © 2026 Творческая лаборатория познавательного развития
    </p>
    <p style="font-size: 0.8rem; color: #7f8c8d; margin: 0;">
        Материалы сайта доступны по лицензии 
        <a href="https://creativecommons.org" target="_blank" style="color: #7f8c8d; text-decoration: underline;">CC BY 4.0</a> (с указанием авторства). 
    </p> 
</footer>

{% include video-logic.liquid %}

</body>
</html>
